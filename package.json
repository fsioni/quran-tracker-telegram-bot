{
  "name": "quran-tracker-telegram-bot",
  "version": "1.0.0",
  "description": "Telegram bot to track Quran reading sessions with prayer time reminders, deployed on Cloudflare Workers",
  "author": "Fares Sioni",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fsioni/quran-tracker-telegram-bot.git"
  },
  "keywords": [
    "telegram-bot",
    "quran",
    "cloudflare-workers",
    "d1",
    "grammy",
    "prayer-times"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "wrangler dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "wrangler deploy",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "grammy": "^1.41.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@cloudflare/workers-types": "^4.20260313.1",
    "miniflare": "^4.20260310.0",
    "typescript": "^5.9.3",
    "ultracite": "^7.3.2",
    "vitest": "^4.1.0",
    "wrangler": "^4.72.0"
  }
}
